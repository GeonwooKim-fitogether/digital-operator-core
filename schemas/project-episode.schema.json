{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digital-operator-core/schemas/project-episode",
  "title": "ProjectEpisode",
  "description": "프로젝트에서 추출된 조직 학습 기록",
  "type": "object",
  "required": [
    "id", "projectId", "companyId", "title", "outcome",
    "keyLearnings", "sourceReferenceIds", "evaluationId", "createdAt"
  ],
  "properties": {
    "id": { "type": "string" },
    "projectId": { "type": "string" },
    "companyId": { "type": "string" },
    "title": { "type": "string" },
    "objective": { "type": "string" },
    "outcome": {
      "type": "string",
      "enum": ["success", "partial", "failure"]
    },
    "outcomeDetails": { "type": "string" },
    "whatWorked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "whatFailed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rootCauses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "falseAssumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "keyLearnings": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "reusablePatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "knowledgeGaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "followUpTasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "companySpecific": {
      "type": "boolean",
      "description": "true이면 회사 전용 지식, false이면 Core 승격 검토 가능"
    },
    "sourceReferenceIds": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evaluationId": { "type": "string" },
    "executionPlanId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
