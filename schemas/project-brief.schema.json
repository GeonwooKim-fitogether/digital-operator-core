{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://digital-operator-core/schemas/project-brief",
  "title": "ProjectBrief",
  "description": "프로젝트 실행의 입력 정의",
  "type": "object",
  "required": ["id", "companyId", "title", "objective", "completionCriteria", "constraints", "requestedAt"],
  "properties": {
    "id": {
      "type": "string",
      "description": "고유 프로젝트 ID"
    },
    "companyId": {
      "type": "string",
      "description": "회사 식별자"
    },
    "title": {
      "type": "string",
      "description": "프로젝트 제목"
    },
    "objective": {
      "type": "string",
      "description": "달성해야 할 목표"
    },
    "completionCriteria": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "완료 조건 목록"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "제약 사항"
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "default": "medium"
    },
    "deadline": {
      "type": "string",
      "format": "date-time"
    },
    "requestedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestedBy": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relatedProjectIds": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
